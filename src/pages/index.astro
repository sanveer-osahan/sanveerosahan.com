---
import { getSection, getSortDate, sortByDate } from "@/data/content";
import { type SectionMeta, SECTIONS, sectionHref } from "@/data/sections";
import PageLayout from "@/layouts/Base.astro";
import { siteConfig } from "@/site-config";
import { formatRailDate } from "@/utils/date";
import { absoluteUrl, withBase } from "@/utils/path";
import { Schema } from "astro-seo-schema";

const HOME_ITEM_LIMIT = 3;

const [books, posts, guides, videos] = await Promise.all([
	getSection("book"),
	getSection("post"),
	getSection("guide"),
	getSection("video"),
]);

/** Minimal shape the hub cards need from any section entry. */
type HomeItem = { id: string; data: { title: string; publishDate: Date; updatedDate?: Date } };

const sections: { meta: SectionMeta; items: HomeItem[] }[] = [
	{ meta: SECTIONS.book, items: sortByDate(books).slice(0, HOME_ITEM_LIMIT) },
	{ meta: SECTIONS.post, items: sortByDate(posts).slice(0, HOME_ITEM_LIMIT) },
	{ meta: SECTIONS.guide, items: sortByDate(guides).slice(0, HOME_ITEM_LIMIT) },
	{ meta: SECTIONS.video, items: sortByDate(videos).slice(0, HOME_ITEM_LIMIT) },
];

const profile = siteConfig.profile;
const siteUrl = (path: string) => absoluteUrl(path, Astro.site);
---

<Schema
	item={{
		"@context": "https://schema.org",
		"@type": "WebSite",
		name: siteConfig.title,
		description: siteConfig.description,
		url: siteUrl("/"),
	}}
/>

<PageLayout meta={{ title: "Home", description: siteConfig.description }}>
	<section class="hero">
		<p>{siteConfig.description}</p>
		<div class="socials">
			{profile?.github && (
				<>
					<a href={profile.github} rel="noreferrer" target="_blank">GitHub</a>
					<span class="sep">·</span>
				</>
			)}
			{profile?.linkedin && (
				<>
					<a href={profile.linkedin} rel="noreferrer" target="_blank">LinkedIn</a>
					<span class="sep">·</span>
				</>
			)}
			{profile?.email && (
				<>
					<a href={`mailto:${profile.email}`}>Email</a>
					<span class="sep">·</span>
				</>
			)}
			<a href={withBase("/rss.xml")}>RSS</a>
		</div>
	</section>

	<div class="sections">
		{
			sections.map(({ meta, items }) => (
				<section class="card" aria-labelledby={`sec-${meta.collection}`}>
					<a class="card-head" data-astro-prefetch href={withBase(`${meta.basePath}/`)}>
						<h2 class="card-title" id={`sec-${meta.collection}`}>
							{meta.title}
						</h2>
						<span class="card-go">View all →</span>
					</a>
					{items.length === 0 ? (
						<p class="card-empty">Nothing here yet.</p>
					) : (
						<ul class="card-list">
							{items.map((item) => (
								<li>
									<a data-astro-prefetch href={withBase(sectionHref(meta.collection, item.id))}>
										<span class="item-title">{item.data.title}</span>
										<time class="item-date" datetime={getSortDate(item).toISOString()}>
											{formatRailDate(getSortDate(item))}
										</time>
									</a>
								</li>
							))}
						</ul>
					)}
				</section>
			))
		}
	</div>
</PageLayout>

<style>
	/* ---------- Hero ---------- */
	.hero {
		margin-bottom: 72px;
	}
	.hero p {
		font-size: 19.5px;
		line-height: 1.65;
		color: hsl(var(--theme-text));
		margin: 0 0 22px;
		max-width: 60ch;
		text-wrap: pretty;
	}
	.socials {
		font-family: var(--font-sans);
		font-size: 13.5px;
		color: hsl(var(--theme-text) / 0.72);
		margin-top: 18px;
	}
	.socials a {
		color: hsl(var(--theme-text-muted));
		text-decoration: underline;
		text-decoration-color: hsl(var(--theme-text) / 0.35);
		text-decoration-thickness: 1px;
		text-underline-offset: 3px;
		transition: color 0.2s ease, text-decoration-color 0.2s ease;
	}
	.socials a:hover {
		color: hsl(var(--theme-accent));
		text-decoration-color: hsl(var(--theme-accent));
	}
	.socials .sep {
		color: var(--faint);
		margin: 0 9px;
	}

	/* ---------- Section cards ---------- */
	.sections {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 40px 48px;
		margin-bottom: 96px;
	}
	.card-head {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 12px;
		padding-bottom: 12px;
		margin-bottom: 14px;
		border-bottom: 1px solid var(--hairline);
	}
	.card-title {
		font-family: var(--font-hand);
		font-weight: 700;
		font-size: 28px;
		line-height: 1;
		color: hsl(var(--theme-accent));
		margin: 0;
	}
	.card-go {
		font-family: var(--font-mono);
		font-size: 11px;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: hsl(var(--theme-text) / 0.55);
		transition: color 0.2s ease;
		white-space: nowrap;
	}
	.card-head:hover .card-go {
		color: hsl(var(--theme-accent));
	}
	.card-list {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.card-list li {
		margin-bottom: 10px;
	}
	.card-list a {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 14px;
	}
	.item-title {
		font-family: var(--font-serif);
		font-size: 16px;
		line-height: 1.4;
		color: hsl(var(--theme-text));
		transition: color 0.2s ease;
		text-wrap: pretty;
	}
	.card-list a:hover .item-title {
		color: hsl(var(--theme-accent));
	}
	.item-date {
		flex: none;
		font-family: var(--font-mono);
		font-size: 11px;
		color: hsl(var(--theme-text) / 0.5);
		font-variant-numeric: tabular-nums;
	}
	.card-empty {
		font-family: var(--font-serif);
		font-style: italic;
		font-size: 15.5px;
		color: hsl(var(--theme-text-muted));
		margin: 0;
	}
	.card-head:focus-visible,
	.card-list a:focus-visible,
	.socials a:focus-visible {
		outline: 2px solid hsl(var(--theme-accent));
		outline-offset: 3px;
		border-radius: 3px;
	}

	@media (max-width: 720px) {
		.hero {
			margin-bottom: 56px;
		}
		.hero p {
			font-size: 18px;
		}
		.sections {
			grid-template-columns: 1fr;
			gap: 36px;
			margin-bottom: 64px;
		}
	}
	@media (max-width: 420px) {
		.hero {
			margin-bottom: 44px;
		}
		.hero p {
			font-size: 17px;
		}
	}
</style>
