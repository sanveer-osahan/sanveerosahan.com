---
import BaseHead from "@/components/BaseHead.astro";
import SkipLink from "@/components/SkipLink.astro";
import ThemeProvider from "@/components/ThemeProvider.astro";
import Footer from "@/components/layout/Footer.astro";
import Header from "@/components/layout/Header.astro";
import { siteConfig } from "@/site-config";
import type { SiteMeta } from "@/types";

interface Props {
	meta: SiteMeta;
}

const {
	meta: { articleDate, description = siteConfig.description, ogImage, title },
} = Astro.props;
---

<html class="scroll-smooth" lang={siteConfig.lang}>
	<head>
		<ThemeProvider />
		<BaseHead articleDate={articleDate} description={description} ogImage={ogImage} title={title} />
	</head>
	<body>
		<SkipLink />
		<div class="wrap">
			<Header />
			<main id="main">
				<slot />
			</main>
			<Footer />
		</div>

		<style is:global>
			html {
				scrollbar-gutter: stable;
			}
			html,
			body {
				margin: 0;
				padding: 0;
				overflow-x: hidden;
			}
			body {
				background-color: hsl(var(--theme-bg));
				color: hsl(var(--theme-text));
				font-family: var(--font-serif);
				font-size: 18px;
				line-height: 1.62;
				font-weight: 400;
				-webkit-font-smoothing: antialiased;
				-moz-osx-font-smoothing: grayscale;
				text-rendering: optimizeLegibility;
				min-height: 100vh;
				min-height: 100dvh;
			}
			html.theme-ready body {
				transition: background-color 0.35s ease, color 0.35s ease;
			}
			a {
				color: inherit;
				text-decoration: none;
				transition: color 0.2s ease, border-color 0.2s ease;
			}

			/* Sticky footer: wrap fills viewport, main grows to push footer down */
			.wrap {
				max-width: 760px;
				margin: 0 auto;
				padding: 36px max(32px, env(safe-area-inset-right))
					max(80px, env(safe-area-inset-bottom)) max(32px, env(safe-area-inset-left));
				min-height: 100vh;
				min-height: 100dvh;
				display: flex;
				flex-direction: column;
			}
			.wrap > main { flex: 1 0 auto; }

			@media (max-width: 720px) {
				.wrap {
					padding: 18px max(22px, env(safe-area-inset-right))
						max(56px, env(safe-area-inset-bottom)) max(22px, env(safe-area-inset-left));
				}
				body {
					font-size: 17px;
				}
			}

			@media (max-width: 420px) {
				.wrap {
					padding: 14px max(16px, env(safe-area-inset-right))
						max(44px, env(safe-area-inset-bottom)) max(16px, env(safe-area-inset-left));
				}
				body {
					font-size: 16.5px;
				}
			}
		</style>

		<script>
			// Theme-aware Mermaid (hand-drawn). Loads only on pages with <pre class="mermaid">.
			const blocks = Array.from(
				document.querySelectorAll<HTMLElement>(".post-article pre.mermaid"),
			);
			if (blocks.length) {
				const { default: mermaid } = await import("mermaid");
				const sources = new WeakMap<HTMLElement, string>();
				blocks.forEach((el) => sources.set(el, el.textContent ?? ""));

				const cssVar = (n: string) =>
					getComputedStyle(document.documentElement).getPropertyValue(n).trim();
				const hsl = (n: string) => `hsl(${cssVar(n)})`;

				const render = async () => {
					const ink = hsl("--theme-text");
					const accent = hsl("--theme-accent");
					const paper = cssVar("--paper") || hsl("--theme-bg");
					mermaid.initialize({
						startOnLoad: false,
						look: "handDrawn",
						theme: "base",
						fontFamily: "Caveat, cursive",
						themeVariables: {
							background: paper,
							primaryColor: paper,
							primaryBorderColor: ink,
							primaryTextColor: ink,
							secondaryColor: paper,
							tertiaryColor: paper,
							lineColor: accent,
							fontSize: "22px",
						},
					});
					for (const el of blocks) {
						el.textContent = sources.get(el) ?? "";
						el.removeAttribute("data-processed");
					}
					await mermaid.run({ nodes: blocks });
				};

				await render();
				// Re-render with new colors when the reader toggles light/dark.
				document.addEventListener("theme-change", () => {
					void render();
				});
			}
		</script>
	</body>
</html>
